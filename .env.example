# === Continuity Studio Pro - Environment Configuration ===

# --- Image Generation (derouter / OpenAI-compatible) ---
DEROUTER_API_KEY=
DEROUTER_BASE_URL=https://api-direct.derouter.network/openai/v1
IMAGE_MODEL=gpt-image-2
REQUEST_TIMEOUT=600

# --- Claude / Anthropic (script gen, vision, planning) ---
CLAUDE_API_KEY=
CLAUDE_BASE_URL=https://api.derouter.network/proxy
CLAUDE_MODEL=claude-sonnet-4-6

# --- ElevenLabs TTS ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_multilingual_v2

# --- Deepgram Aura TTS ---
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=aura-2-thalia-en

# --- Piper TTS (local, free) ---
PIPER_VOICE=amy
PIPER_USE_GPU=false

# --- Google OAuth (YouTube upload) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- OpenRouter (fallback image gen) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=sourceful/riverflow-v2.5-pro:free

# --- Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Render Settings ---
DEFAULT_SIZE=1536x1024
DEFAULT_QUALITY=medium

# --- Auth ---
AUTH_REQUIRED=false
SESSION_SECRET=change-this-in-production
